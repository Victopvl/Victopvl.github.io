---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

// Clonamos y ordenamos las publicaciones desde la más reciente
const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Feed de Actualizaciones | Victoria Vallejos" sideBarActiveItemID="blog">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Feed de Actualizaciones</div>
    <p class="text-sm text-base-content/70 mt-2">
      Bitácora en tiempo real sobre proyectos, hackatones, aprendizajes técnicos y el "Build in Public" de Datavolve.
    </p>
  </div>

  {
    posts.length === 0 ? (
      <div class="bg-base-100 border border-base-300 rounded-xl p-8 text-center mt-8">
        <p class="text-base-content/70 text-sm">Aún no hay publicaciones en tu feed. ¡Es momento de lanzar la primera!</p>
      </div>
    ) : (
      <div class="space-y-6 mt-8 max-w-3xl">
        {posts.map((post) => (
          <div class="border border-base-300 bg-base-100 rounded-xl p-6 shadow-sm hover:shadow-md transition-all flex flex-col justify-between">
            <div>
              <div class="flex items-center gap-3 mb-3">
                <span class="text-[10px] uppercase font-extrabold tracking-wider px-2 py-0.5 rounded bg-blue-100 text-blue-800">
                  {post.data.badge || "Actualización"}
                </span>
                <span class="text-xs text-base-content/60 font-medium">
                  {post.data.pubDate.toLocaleDateString("es-CL", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </span>
              </div>

              <h3 class="text-xl font-bold mb-2 text-base-content hover:text-blue-700 transition-colors">
                <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
              </h3>

              <p class="text-sm text-base-content/80 leading-relaxed mb-4">
                {post.data.description}
              </p>
            </div>

            <div class="flex items-center justify-between flex-wrap gap-3 pt-3 border-t border-base-200 mt-2">
              <div class="flex flex-wrap gap-1.5">
                {post.data.tags &&
                  post.data.tags.map((tag) => (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-base-200 text-base-content/70 font-medium">
                      #{tag}
                    </span>
                  ))}
              </div>
              <a
                href={`/blog/${post.slug}/`}
                class="text-xs font-semibold text-blue-700 hover:text-blue-800 transition-colors flex items-center gap-1"
              >
                Ver publicación completa →
              </a>
            </div>
          </div>
        ))}
      </div>
    )
  }
</BaseLayout>