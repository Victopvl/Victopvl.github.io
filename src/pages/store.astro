---
import BaseLayout from "../layouts/BaseLayout.astro";
import { assetsData } from "../data/assets";
---

<BaseLayout title="Plantillas y Recursos | Victoria Vallejos" sideBarActiveItemID="store">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Plantillas y Recursos de Código</div>
    <p class="text-sm text-neutral-content mb-10">
      Repositorios abiertos y estructuras base desarrollados para optimizar la implementación de software, automatizaciones y arquitectura de datos.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {assetsData.map((asset) => (
      <div class="border border-base-300 bg-base-100 rounded-xl p-6 shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
        <div>
          <div class="flex items-center justify-between mb-3">
            <span class="text-[10px] uppercase font-extrabold tracking-wider px-2 py-0.5 rounded bg-slate-100 text-slate-700">
              {asset.badge}
            </span>
            <span class="text-xs font-semibold text-success">
              Open Source
            </span>
          </div>
          <h3 class="text-lg font-bold mb-2 text-base-content">{asset.title}</h3>
          <p class="text-xs text-neutral-content leading-relaxed mb-6">
            {asset.description}
          </p>
        </div>
        <div>
          <a
            href={asset.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-sm btn-outline w-full normal-case font-medium text-xs rounded-lg hover:bg-slate-900 hover:text-white transition-colors"
          >
            Ver en GitHub
          </a>
        </div>
      </div>
    ))}
  </div>
</BaseLayout>