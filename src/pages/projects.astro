---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { projectsData } from "../data/projects";

// Filtramos de forma automatizada por la categoría declarada en el archivo central
const datavolveProjects = projectsData.filter(p => p.category === "Datavolve B2B");
const personalProjects = projectsData.filter(p => p.category === "Desarrollo Personal y Academia");
---

<BaseLayout title="Proyectos | Victoria Vallejos" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Proyectos y Consultoría</div>
    <p class="text-sm text-neutral-content mb-8">
      Registro y evolución de soluciones tecnológicas, ingeniería de datos e iniciativas de automatización activa.
    </p>
  </div>

  <div class="mb-5 mt-6">
    <div class="text-2xl w-full font-bold text-primary mb-2">📊 Soluciones Corporativas & Ecosistema Datavolve</div>
    <div class="h-0.5 w-full bg-base-300 mb-6"></div>
  </div>

  <div class="grid gap-4">
    {datavolveProjects.map((project) => (
      <HorizontalCard
        title={project.title}
        img={project.image}
        desc={project.description}
        url={project.url}
        badge={project.badge}
      />
    ))}
  </div>

  <div class="mb-5 mt-12">
    <div class="text-2xl w-full font-bold text-primary mb-2">💻 Ingeniería Aplicada & Desarrollo Personal</div>
    <div class="h-0.5 w-full bg-base-300 mb-6"></div>
  </div>

  <div class="grid gap-4">
    {personalProjects.map((project) => (
      <HorizontalCard
        title={project.title}
        img={project.image}
        desc={project.description}
        url={project.url}
        badge={project.badge}
      />
    ))}
  </div>
</BaseLayout>