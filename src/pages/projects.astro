---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { projectsData } from "../data/projects";

// Filtramos de forma automatizada por la categoría declarada en el archivo de datos
const datavolveProjects = projectsData.filter(p => p.category === "Datavolve B2B");
const personalProjects = projectsData.filter(p => p.category === "Desarrollo Personal y Academia");
---

<BaseLayout title="Proyectos | Victoria Vallejos" sideBarActiveItemID="projects">
  <div class="pb-6 mt-5">
    <div class="text-3xl w-full font-bold text-base-content">Proyectos y Consultoría</div>
    <p class="text-base text-base-content/70 mt-2">
      Registro y evolución de soluciones tecnológicas, ingeniería de datos e iniciativas de automatización activa.
    </p>
  </div>

  <div class="mb-6 mt-6">
    <div class="text-2xl w-full font-bold text-primary">Soluciones Corporativas & Ecosistema Datavolve</div>
    <div class="divider mt-1 mb-6"></div>
  </div>

  <div class="space-y-0">
    {datavolveProjects.map((project, index) => (
      <>
        <HorizontalCard
          title={project.title}
          img={project.image}
          desc={project.description}
          url={project.url}
          badge={project.badge}
        />
        {index < datavolveProjects.length - 1 && <div class="divider my-0" />}
      </>
    ))}
  </div>

  <div class="mb-6 mt-14">
    <div class="text-2xl w-full font-bold text-primary">Ingeniería Aplicada & Desarrollo Personal</div>
    <div class="divider mt-1 mb-6"></div>
  </div>

  <div class="space-y-0">
    {personalProjects.map((project, index) => (
      <>
        <HorizontalCard
          title={project.title}
          img={project.image}
          desc={project.description}
          url={project.url}
          badge={project.badge}
        />
        {index < personalProjects.length - 1 && <div class="divider my-0" />}
      </>
    ))}
  </div>
</BaseLayout>