---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";

// Obtenemos los posts ordenados por fecha más reciente
const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Tomamos solo los últimos 3 para la vista de inicio
const last_posts = posts.slice(0, 3);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="px-8 pt-4 pb-6"> <!-- Reducido el padding superior e inferior -->
    <div class="text-sm py-0.5 text-base-content/70 font-medium uppercase tracking-wider">Perfil de presentación y portafolio profesional</div>
    <div class="text-4xl font-bold text-base-content tracking-tight">Victoria Vallejos</div>
    <div class="text-xl py-2 font-semibold text-base-content/90 leading-snug">Managing Consultant & Desarrolladora — Ingeniería Civil Informática, Universidad Andrés Bello</div>
    
    <div class="py-1">
      <p class="text-lg text-primary font-medium leading-relaxed max-w-4xl">
        Diseño e implemento soluciones tecnológicas para negocios y organizaciones, combinando desarrollo web, automatización de procesos y una visión estratégica de gestión.
      </p>
    </div>
    
    <div class="py-1">
      <p class="text-base text-base-content/85 leading-relaxed max-w-3xl">
        Estudiante de Ingeniería Civil Informática, con experiencia liderando iniciativas de transformación digital y participación activa en comunidades tecnológicas y de emprendimiento — Embajadora en Tertulias (Comunidad de IA) y Líder de Marketing en el Club de Emprendedores UNAB.
Combino formación técnica con metodologías ágiles y comunicación estratégica, desarrollando soluciones que van desde sitios web y automatización de procesos hasta análisis y organización de datos para negocios y equipos.
      </p>
    </div>
    
    <div class="mt-6 flex flex-wrap gap-3"> <!-- Botones más juntos y con un margen superior normalizado -->
      <a class="btn btn-primary text-white normal-case px-6 shadow-sm rounded-lg" href="https://www.linkedin.com" target="_blank">
        Conectemos en LinkedIn
      </a>
      <a href="mailto:victoriapaz.sa@gmail.com" class="btn btn-outline normal-case px-6 rounded-lg">
        Iniciar Contacto
      </a>
    </div>
  </div>
</BaseLayout>

  <div>
    <div class="text-3xl w-full font-bold mb-6 text-base-content">Proyectos Destacados</div>
  </div>

  <HorizontalCard
    title="Ecosistema Datavolve"
    img="/post_img.png"
    desc="Plataforma centralizada de consultoría enfocada en transformación digital, analítica de datos avanzada y automatización para el crecimiento organizacional."
    url="/projects"
    target="_self"
    badge="Consultoría"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Modelos y Automatización con IA"
    img="/post_img.png"
    desc="Diseño de agentes inteligentes y estructuras base capaces de procesar información compleja y optimizar flujos operativos corporativos."
    url="/projects"
    target="_self"
    badge="Innovación"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Repositorios y Plantillas de Código Abierto"
    img="/post_img.png"
    desc="Desarrollo de estructuras limpias y modulares open-source destinadas a acelerar la arquitectura de software."
    url="/projects"
    target="_self"
    badge="OSS"
  />

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-14 text-base-content">Últimas publicaciones del Feed</div>
  </div>

  {
    last_posts.length === 0 ? (
      <p class="text-sm text-base-content/60 italic bg-base-200/50 p-4 rounded-lg border border-neutral/10">
        Pronto compartiré las primeras actualizaciones de mi bitácora técnica.
      </p>
    ) : (
      last_posts.map((post, index) => (
        <>
          <HorizontalCard
            title={post.data.title}
            img={post.data.heroImage}
            desc={post.data.description}
            url="/blog"
            target="_self"
            badge={post.data.badge}
          />
          {index < last_posts.length - 1 && <div class="divider my-0" />}
        </>
      ))
    )
  }
</BaseLayout>