---
import BaseLayout from "../layouts/BaseLayout.astro";
import { certificationsData } from "../data/certifications";
---

<BaseLayout title="Certificaciones | Victoria Vallejos" sideBarActiveItemID="certifications">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Certificaciones y Formación Adicional</div>
    <p class="text-sm text-base-content/70 mt-2">Un registro interactivo de mis competencias validadas, microcursos y webinars.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
    {certificationsData.map((cert) => (
      <div class="border border-base-300 bg-base-100 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow flex flex-col justify-between">
        
        <div class="p-5">
          <div class="flex items-start gap-4 mb-4">
            <img src={cert.image} alt={cert.title} class="w-16 h-16 object-contain rounded bg-slate-50 p-1 border border-slate-100" />
            <div>
              <span class="text-[10px] uppercase font-extrabold tracking-wider px-2 py-0.5 rounded bg-blue-100 text-blue-800 mb-1 inline-block">
                {cert.category}
              </span>
              <h3 class="font-bold text-lg leading-tight text-base-content">{cert.title}</h3>
              <p class="text-sm text-base-content/70">{cert.institution} • <span class="text-xs">{cert.date}</span></p>
            </div>
          </div>

          <div class="bg-slate-50 border-l-4 border-blue-500 p-3 rounded-r text-sm text-base-content/80 italic mb-4">
            "{cert.comment}"
          </div>

          <div class="flex flex-wrap gap-1.5 mb-2">
            {cert.tags.map((tag) => (
              <span class="text-xs px-2.5 py-0.5 rounded-full bg-slate-200 text-slate-700 font-medium">
                #{tag}
              </span>
            ))}
          </div>
        </div>

        <div class="px-5 py-3 bg-slate-50 border-t border-base-200 flex justify-end">
          <a href={cert.url} target="_blank" class="btn btn-sm btn-outline btn-primary normal-case font-medium">
            Ver Credencial Oficial →
          </a>
        </div>

      </div>
    ))}
  </div>
</BaseLayout>