---
import BaseLayout from "../layouts/BaseLayout.astro";
import { certificationsData } from "../data/certifications";
---

<BaseLayout title="Certificaciones | Victoria Vallejos" sideBarActiveItemID="certifications">
  <div class="pb-6 mt-5">
    <h1 class="text-3xl w-full font-bold text-base-content">Certificaciones y Formación Adicional</h1>
    <p class="text-base text-base-content/70 mt-2">Un registro interactivo de mis competencias validadas, microcursos y webinars.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
    {certificationsData.map((cert) => (
      <div class="border border-neutral/10 bg-base-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all flex flex-col justify-between">
        
        <div class="p-5">
          <div class="flex items-start gap-4 mb-4">
            <img src={cert.image} alt={cert.title} class="w-16 h-16 object-contain rounded bg-base-100 p-2 border border-neutral/5 shrink-0" />
            <div>
              <span class="text-[10px] uppercase font-extrabold tracking-wider px-2.5 py-1 rounded bg-primary/10 text-primary mb-1.5 inline-block">
                {cert.category}
              </span>
              <h3 class="font-bold text-lg leading-tight text-base-content">{cert.title}</h3>
              <p class="text-xs text-base-content/60 mt-0.5 font-medium">{cert.institution} • <span>{cert.date}</span></p>
            </div>
          </div>

          <div class="bg-base-100 border-l-4 border-primary p-3 rounded-r text-xs text-base-content/80 italic mb-4 leading-relaxed">
            "{cert.comment}"
          </div>

          <div class="flex flex-wrap gap-1.5 mb-2">
            {cert.tags.map((tag) => (
              <span class="text-xs px-2.5 py-0.5 rounded-full bg-base-100 border border-neutral/5 text-base-content/70 font-medium">
                #{tag}
              </span>
            ))}
          </div>
        </div>

        <div class="px-5 py-3 bg-base-100/50 border-t border-neutral/5 flex justify-end">
          <a href={cert.url} target="_blank" class="btn btn-sm btn-outline btn-primary normal-case font-medium px-4">
            Ver Credencial Oficial →
          </a>
        </div>

      </div>
    ))}
  </div>
</BaseLayout>