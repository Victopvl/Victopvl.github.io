---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contacto | Victoria Vallejos" sideBarActiveItemID="contacto">
  <div class="mt-5">
    <div class="text-3xl w-full font-bold mb-5 text-slate-900">Contacto</div>
  </div>

  <div class="mb-10">
    <h2 class="text-xl font-semibold mb-4 text-slate-800">Redes y Canales Personales</h2>
    <p class="mb-6 text-sm text-base-content/70">
      Conectemos a nivel profesional, revisa mis proyectos técnicos o escríbeme directamente a mis canales informales.
    </p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      
      <a href="https://www.linkedin.com/in/victoria-paz-vallejos-luna-57a18a344/" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-4 p-4 bg-base-100 rounded-xl border border-base-300 hover:bg-base-300 hover:border-slate-500 transition-all duration-200 hover:shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-6 h-6 fill-current text-slate-800 transition-colors">
          <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
        </svg>
        <div>
          <div class="font-bold text-sm text-slate-900">LinkedIn</div>
          <div class="text-xs text-base-content/60">Conectemos profesionalmente</div>
        </div>
      </a>

      <a href="https://www.instagram.com/victopvl" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-4 p-4 bg-base-100 rounded-xl border border-base-300 hover:bg-base-300 hover:border-slate-500 transition-all duration-200 hover:shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-6 h-6 fill-current text-slate-800 transition-colors">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        <div>
          <div class="font-bold text-sm text-slate-900">Instagram</div>
          <div class="text-xs text-base-content/60">Un vistazo más cercano</div>
        </div>
      </a>

      <a href="https://github.com/Victopvl" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-4 p-4 bg-base-100 rounded-xl border border-base-300 hover:bg-base-300 hover:border-slate-500 transition-all duration-200 hover:shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-6 h-6 fill-current text-slate-800 transition-colors">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        <div>
          <div class="font-bold text-sm text-slate-900">GitHub</div>
          <div class="text-xs text-base-content/60">Mi código y repositorios</div>
        </div>
      </a>

      <a href="https://wa.me/56949745464" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-4 p-4 bg-base-100 rounded-xl border border-base-300 hover:bg-base-300 hover:border-slate-500 transition-all duration-200 hover:shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-6 h-6 fill-current text-slate-800 transition-colors">
          <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.713-1.455L0 24zm6.79-4.024l.399.237c1.474.875 3.189 1.336 4.947 1.337 5.567 0 10.096-4.529 10.099-10.097.001-2.698-1.046-5.234-2.949-7.139C17.436 2.408 14.9 1.36 12.203 1.36 6.634 1.36 2.105 5.89 2.102 11.459c-.001 1.83.48 3.619 1.392 5.19l.259.447-1.018 3.718 3.812-.998z"/>
        </svg>
        <div>
          <div class="font-bold text-sm text-slate-900">WhatsApp</div>
          <div class="text-xs text-base-content/60">Escríbeme un mensaje directo</div>
        </div>
      </a>

      <a href="https://mail.google.com/mail/?view=cm&fs=1&to=victoriapaz.sa@gmail.com" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-4 p-4 bg-base-100 rounded-xl border border-base-300 hover:bg-base-300 hover:border-slate-500 transition-all duration-200 hover:shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-6 h-6 fill-current text-slate-800 transition-colors">
          <path d="M24 4.5v15c0 .85-.65 1.5-1.5 1.5H21V7.38l-9 5.65-9-5.65V21H1.5C.65 21 0 20.35 0 19.5v-15c0-.85.65-1.5 1.5-1.5H3l9 5.65L21 3h1.5c.85 0 1.5.65 1.5 1.5z"/>
        </svg>
        <div>
          <div class="font-bold text-sm text-slate-900">Correo Electrónico</div>
          <div class="text-xs text-base-content/60">victoriapaz.sa@gmail.com</div>
        </div>
      </a>

      <a href="/projects" class="group flex items-center gap-4 p-4 bg-base-100 rounded-xl border border-base-300 hover:bg-base-300 hover:border-slate-500 transition-all duration-200 hover:shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-6 h-6 fill-current text-slate-800 transition-colors">
          <path d="M22 6h-6v-2c0-1.1-.9-2-2-2h-4c-1.1 0-2 .9-2 2v2h-6c-1.1 0-2 .9-2 2v12c0 1.1-.9 2 2 2h20c1.1 0 2-.9 2-2v-12c0-1.1-.9-2-2-2zm-12-2h4v2h-4v-2zm12 16h-20v-8h20v8zm-10-6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
        </svg>
        <div>
          <div class="font-bold text-sm text-slate-900">Ver Proyectos</div>
          <div class="text-xs text-base-content/60">Explora mi portafolio técnico</div>
        </div>
      </a>

    </div>
  </div>

  <div class="divider my-10"></div>

  <div class="mt-6 bg-base-200 p-8 rounded-2xl border border-base-300 flex flex-col items-center shadow-sm">
    <h2 class="text-2xl font-bold text-center mb-1 text-primary">Datavolve</h2>
    <h3 class="text-sm font-medium text-center mb-4 text-base-content/70">Consultoría TI & Transformación Digital</h3>
    
    <p class="text-sm text-center mb-6 max-w-md text-base-content/80 balance">
      Si buscas automatizar procesos, implementar soluciones de Inteligencia Artificial o requieres asesoría estratégica para tu empresa, coordinemos una reunión corporativa.
    </p>
    
    <a 
      href="https://taplink.cc/datavolve"
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-primary flex items-center justify-center gap-2 px-8 font-semibold shadow-md text-sm tracking-wide normal-case"
    >
      <span>📅</span>
      <span>Agendar una Consultoría</span>
    </a>
  </div>
</BaseLayout>