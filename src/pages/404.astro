---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Página no encontrada | Victoria Vallejos" includeSidebar={false}>
  <div class="text-center flex flex-col items-center justify-center min-h-[70vh] px-4">
    <div class="text-8xl mb-4 animate-bounce">🔍</div>
    
    <h1 class="text-9xl font-extrabold text-base-content tracking-tighter mb-2">404</h1>
    
    <h2 class="text-2xl font-semibold text-base-content mb-2">Página no encontrada</h2>
    <p class="text-base text-base-content/70 max-w-md mb-8">
      Lo siento, la ruta a la que intentas acceder no existe o fue movida a otra ubicación dentro del ecosistema.
    </p>
    
    <a class="btn btn-primary text-white normal-case px-8 shadow-sm" href="/">
      Regresar al Inicio
    </a>
  </div>
</BaseLayout>