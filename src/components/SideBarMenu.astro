---
const { sideBarActiveItemID } = Astro.props;
const activeClass = "bg-base-300"; // Puedes cambiarlo por "active" si quieres usar el color principal del tema
---

<ul class="menu grow shrink menu-md">
    <li><a class="py-3 text-base" id="home" href="/">Inicio</a></li>
    <li><a class="py-3 text-base" id="projects" href="/projects">Proyectos</a></li>
    <li><a class="py-3 text-base" id="services" href="/services">Servicios</a></li>
    <li><a class="py-3 text-base" id="blog" href="/blog/">Feed</a></li>
    <li><a class="py-3 text-base" id="cv" href="/cv">CV</a></li>
    <li><a class="py-3 text-base" id="certifications" href="/certifications">Certificaciones</a></li>
    <li>
        <a
        class="py-3 text-base"
        id="contacto"
        href="/contacto">Contacto</a>
    </li>
</ul>

<script data-astro-rerun define:vars={{ sideBarActiveItemID: sideBarActiveItemID, activeClass: activeClass }}>
  const activeItemElem = document.getElementById(sideBarActiveItemID);
  if (activeItemElem) {
    activeItemElem.classList.add(activeClass);
  }
</script>